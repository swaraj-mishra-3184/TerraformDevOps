provider "aws" {
  region = "us-east-2"
}

variable "server_config" {
  default = {
    instance_type = "t3.micro"
    user_name     = "itw"
  }
}

resource "aws_instance" "web" {
  ami           = "ami-0741dc526e1106ae5"
  instance_type = var.server_config.instance_type
}

resource "aws_iam_user" "user" {
  name = var.server_config.user_name
}
