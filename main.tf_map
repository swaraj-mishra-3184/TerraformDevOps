provider "aws" {
  region = "us-east-2"
}

variable "instance_types" {
  default = {
    dev  = "t3.micro"
    test = "t3.small"
    prod = "m7i-flex.large"
  }
}

resource "aws_instance" "web" {
  ami           = "ami-0741dc526e1106ae5"
  instance_type = var.instance_types["prod"]

  tags = {
    Name = "production-server"
  }
}
